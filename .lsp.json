{
  "cangjie": {
    "command": "~/.harmonyosdev/sdk/cangjie/tools/bin/LSPServer",
    "extensionToLanguage": {
      ".cj": "cangjie"
    },
    "env": {
      "CANGJIE_HOME": "~/.harmonyosdev/sdk/cangjie",
      "DYLD_LIBRARY_PATH": "~/.harmonyosdev/sdk/cangjie/tools/lib:${DYLD_LIBRARY_PATH}"
    },
    "transport": "stdio",
    "startupTimeout": 10000,
    "maxRestarts": 3
  }
}
